{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A5 UX Evaluator Output",
  "type": "object",
  "required": ["eval_id", "overall_pass", "checks"],
  "properties": {
    "eval_id": { "type": "string" },
    "overall_pass": { "type": "boolean" },
    "total_checks": { "type": "integer" },
    "passed_checks": { "type": "integer" },
    "failed_checks": { "type": "integer" },
    "skipped_checks": { "type": "integer" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "pass", "evidence", "category"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "pass": { "type": "boolean" },
          "evidence": { "type": "string" },
          "category": { "type": "string", "enum": ["css", "html", "js", "backend", "ux"] },
          "actual_value": { "type": "string" },
          "expected_value": { "type": "string" },
          "screenshot_path": { "type": "string" }
        }
      }
    },
    "ux_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issue", "severity", "check_id"],
        "properties": {
          "issue": { "type": "string" },
          "severity": { "type": "string" },
          "check_id": { "type": "string" },
          "fix_suggestion": { "type": "string" }
        }
      }
    },
    "browser_console_errors": { "type": "array", "items": { "type": "string" } }
  }
}
