{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A0 Orchestrator Input",
  "type": "object",
  "required": ["orchestration_id"],
  "properties": {
    "orchestration_id": {
      "type": "string",
      "description": "唯一協調 ID，用於關聯所有 Agent 輸出"
    },
    "mode": {
      "type": "string",
      "enum": ["full_cycle", "quick_check", "fix_only", "review_only"],
      "default": "full_cycle"
    },
    "max_cycles": {
      "type": "integer",
      "default": 5,
      "minimum": 1,
      "maximum": 10
    },
    "target_url": {
      "type": "string",
      "default": "http://localhost:8765"
    },
    "auto_commit": {
      "type": "boolean",
      "default": false
    },
    "focus_bugs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "skip_agents": {
      "type": "array",
      "items": { "type": "string", "enum": ["A2", "A3", "A4", "A5", "A6", "A7"] }
    },
    "game_source_dir": {
      "type": "string",
      "default": "C:\\Users\\qwqwh\\.claude\\projects\\multi-agent-plan\\output"
    }
  }
}
